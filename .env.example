# ─── SDG Quest Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in the values before running.
# Never commit your actual .env file to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# MongoDB connection string
# Local Dev:      mongodb://localhost:27017
# Docker Compose: mongodb://mongo:27017
# Atlas:          mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_URL=mongodb+srv://jainamdoshi24_db_user:Jainam2402@game.ia7ankj.mongodb.net/

# JWT secret — use a long random string in production
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_BEFORE_PRODUCTION_USE

# ── Optional ──────────────────────────────────────────────────────────────────

# Backend port (default: 5000)
PORT=5000

# JWT expiry duration (default: 7d)
JWT_EXPIRES=7d

# Frontend URL for CORS (production only)
# FRONTEND_URL=https://sdgquest.example.com

# Node environment: development | production | test
NODE_ENV=development
